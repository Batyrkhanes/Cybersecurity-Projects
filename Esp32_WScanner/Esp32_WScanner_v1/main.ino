/* ===== Wi-Fi Monitor ===== */
enum StatusLevel {
  STATUS_OK,
  STATUS_HIGH,
  STATUS_SUSPICIOUS
};


void wifiMonitor() {
  exitWifiMonitor = false;
	tft.fillScreen(ILI9341_BLACK);
  tft.setTextSize(3);
  tft.setTextColor(ILI9341_GREEN, ILI9341_BLACK);
  tft.setCursor(10, 5);
  tft.print("Wi-Fi Monitor");

  wm_packets = 0;
  wm_rssiSum = 0;
  wm_rssiCount = 0;
  wm_lastPackets = 0;

  for (int i = 0; i < 40; i++) {
    wm_ppsHistory[i] = 0;
  }

  volatile uint32_t beaconPackets = 0;
  volatile uint32_t dataPackets   = 0;
  volatile uint32_t probePackets  = 0;

  WiFi.mode(WIFI_MODE_STA);
  esp_wifi_set_promiscuous(false);
  esp_wifi_set_promiscuous_rx_cb(wifiSniffer);
  esp_wifi_start();
  esp_wifi_set_promiscuous(true);

  wm_lastSecond = millis();
  wm_lastPackets = 0;
  wm_graphIndex = 0;

  // Initialize UI State
  StatusLevel currentStatus = STATUS_OK;
  uint16_t currentStatusColor = ILI9341_GREEN;
  
  // Initial Background Draw of Status Bar
  tft.fillRect(0, 40, tft.width(), 30, currentStatusColor);
  
  // Initial Labels inside Status Bar
  tft.setTextColor(ILI9341_BLACK, currentStatusColor);
  tft.setTextSize(2);
  tft.setCursor(10, 48);
  tft.print("STATUS: OK");

  // Initial Labels for Data (Black Background)
  tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK);
  tft.setCursor(10, 80);
  tft.print("PPS: 0");
  tft.setCursor(130, 80);
  tft.print("RSSI: 0 dBm");
  tft.setCursor(10, 105);
  tft.print("Packets: 0");

  unsigned long lastFastUpdate = 0;

  while (true) {
    // Check button - Exit to Menu
    if (digitalRead(button_left) == LOW) {
  exitWifiMonitor = true;
}
	if (exitWifiMonitor) {
		esp_wifi_set_promiscuous(false);
		esp_wifi_stop();
		WiFi.mode(WIFI_OFF);

		delay(200);
		drawMenu();
		return;
}


    unsigned long currentMillis = millis();

    // ===== FAST UI UPDATE (Every 50ms) =====
    if (currentMillis - lastFastUpdate >= 50) {
      lastFastUpdate = currentMillis;

      // Estimate live RSSI
      int liveRSSI = (wm_rssiCount > 0) ? wm_rssiSum / wm_rssiCount : -100;

      tft.setTextSize(2);
      tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK); // Black background for data
      
      // Update RSSI (Fast) at Y=80 (Right side)
      tft.setCursor(130, 80);
      tft.printf("RSSI: %d dBm  ", liveRSSI);

      // Update Packets Total (Fast) at Y=105
      tft.setCursor(10, 105);
      tft.printf("Packets: %d   ", wm_packets);
    }

    // ===== SLOW LOGIC UPDATE (Every 1000ms) =====
    if (currentMillis - wm_lastSecond >= 1000) {
      wm_lastSecond = currentMillis;
      
      uint32_t currentPPS = wm_packets - wm_lastPackets;
      wm_lastPackets = wm_packets;

      int avgRSSI = (wm_rssiCount > 0) ? wm_rssiSum / wm_rssiCount : -100;
      
      // Reset logic counters
      wm_rssiSum = 0;
      wm_rssiCount = 0;

      wm_ppsHistory[wm_graphIndex] = currentPPS;
      wm_graphIndex = (wm_graphIndex + 1) % 40;

      // Status Logic
      uint32_t avgPPS = 0;
      for (int i = 0; i < 40; i++) avgPPS += wm_ppsHistory[i];
      avgPPS /= 40;

      StatusLevel newStatus = STATUS_OK;
      if (avgPPS > 50 && currentPPS > avgPPS * 3) newStatus = STATUS_SUSPICIOUS;
      else if (currentPPS > 300) newStatus = STATUS_HIGH;

      // Determine colors
      uint16_t newStatusColor = ILI9341_GREEN;
      const char* statusText = "OK";
      if (newStatus == STATUS_HIGH) { newStatusColor = ILI9341_YELLOW; statusText = "HIGH TRAFFIC"; }
      else if (newStatus == STATUS_SUSPICIOUS) { newStatusColor = ILI9341_RED; statusText = "SUSPICIOUS"; }

      // Redraw Status Bar Background ONLY if changed
      if (newStatus != currentStatus) {
        tft.fillRect(0, 40, tft.width(), 30, newStatusColor);
        tft.setTextColor(ILI9341_BLACK, newStatusColor);
        tft.setTextSize(2);
        tft.setCursor(10, 48);
        tft.print("STATUS: ");
        tft.print(statusText);
        
        currentStatus = newStatus;
        currentStatusColor = newStatusColor;
        
        // Alert sound
        if (newStatus == STATUS_SUSPICIOUS) {
           tone(buzzer, 1200, 80);
        }
      }

      // Update PPS (1Hz) at Y=80 (Left side)
      tft.setTextSize(2);
      tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK); // Black background
      tft.setCursor(10, 80);
      tft.printf("PPS: %d   ", currentPPS);

      
      // Update RSSI Bar at Y=200
      int rssiBar = map(avgRSSI, -100, -30, 0, 100);
      rssiBar = constrain(rssiBar, 0, 100);
      tft.fillRect(10 + rssiBar * 2, 200, 200 - rssiBar * 2, 8, ILI9341_BLACK); // Clear tail
      tft.fillRect(10, 200, rssiBar * 2, 8, ILI9341_CYAN); // Draw bar
      tft.drawRect(10, 200, 200, 8, ILI9341_DARKGREY); // Draw frame

      drawWmGraph();
    }
  }
}


void drawBar(int x, int y, int w, int h, int val, int maxVal, uint16_t color) {
    tft.drawRect(x, y, w, h, ILI9341_DARKGREY);
    int barW = map(val, 0, maxVal, 0, w-2);
    barW = constrain(barW, 0, w-2);
    tft.fillRect(x+1, y+1, barW, h-2, color);
}

/* ===== VULNERABILITIES ===== */
void vulnerabilities() {
  // 1. Show immediate feedback
  tft.fillScreen(ILI9341_BLACK);
  tft.setTextSize(2);
  tft.setTextColor(ILI9341_ORANGE);
  tft.setCursor(50, 10);
  tft.print("VULNERABILITIES");
  tft.drawFastHLine(0, 35, 320, ILI9341_DARKGREY);
  
  tft.setTextSize(3);
  tft.setCursor(10, 50);
  tft.setTextColor(ILI9341_YELLOW);
  tft.print("Scanning...");

  // 2. Perform scan (blocking)
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  int n = WiFi.scanNetworks();

  if (n <= 0) {
    tft.fillRect(0, 40, 320, 200, ILI9341_BLACK);
    tft.setTextColor(ILI9341_RED);
    tft.setTextSize(2);
    tft.setCursor(10, 50);
    tft.print("No networks found");
    delay(2000);
    drawMenu();
    return;
  }

  int selected = 0;
  int scroll = 0;
  const int perPage = 5;
  bool redraw = true;

  while (true) {
    if (digitalRead(button_down) == LOW) {
      selected++;
      if (selected >= n) selected = 0;
      if (selected >= scroll + perPage) scroll = selected - perPage + 1;
      if (selected < scroll) scroll = selected;
      redraw = true;
      delay(150);
    }

    if (digitalRead(button_up) == LOW) {
      selected--;
      if (selected < 0) selected = n - 1;
      if (selected < scroll) scroll = selected;
      if (selected >= scroll + perPage) scroll = selected - perPage + 1;
      redraw = true;
      delay(150);
    }

    if (digitalRead(button_left) == LOW) {
      delay(200);
      break;
    }

    // ==== DRAW ====
    if (redraw) {
      tft.fillRect(0, 36, 320, 204, ILI9341_BLACK);
      int y = 45;

      for (int i = 0; i < perPage; i++) {
        int idx = scroll + i;
        if (idx >= n) break;

        String ssid = WiFi.SSID(idx);
        if (ssid.length() > 18) ssid = ssid.substring(0, 15) + "...";

        String issues = "";
        int risk = 0;

        wifi_auth_mode_t enc = WiFi.encryptionType(idx);
        if (enc == WIFI_AUTH_OPEN) { issues += "Open, "; risk += 2; }
        else if (enc == WIFI_AUTH_WEP) { issues += "WEP, "; risk += 2; }
        else if (enc == WIFI_AUTH_WPA_PSK) { issues += "WPA, "; risk += 1; }

        int dup = 0;
        for (int j = 0; j < n; j++) {
          if (WiFi.SSID(j) == WiFi.SSID(idx)) dup++;
        }
        if (dup > 1) { issues += "Duplicate SSID, "; risk += 1; }

        if (issues.length() == 0) issues = "No issues";
        else issues.remove(issues.length() - 2);

        String riskText = "SECURE";
        uint16_t color = ILI9341_GREEN;
        if (risk == 1) { riskText = "MEDIUM"; color = ILI9341_YELLOW; }
        else if (risk == 2) { riskText = "HIGH"; color = ILI9341_ORANGE; }
        else if (risk >= 3) { riskText = "CRITICAL"; color = ILI9341_RED; }

        if (idx == selected) {
          tft.fillRoundRect(5, y, 310, 34, 5, ILI9341_BLUE);
          tft.drawRoundRect(5, y, 310, 34, 5, ILI9341_WHITE);
        } else {
          tft.drawRoundRect(5, y, 310, 34, 5, ILI9341_DARKGREY);
        }

        tft.setTextSize(2);
        tft.setTextColor(ILI9341_WHITE);
        tft.setCursor(10, y + 2);
        tft.print(ssid);

        tft.setTextSize(1);
        tft.setTextColor(color);
        tft.setCursor(10, y + 20);
        tft.print(riskText);
        tft.print(" - ");
        tft.print(issues);

        y += 38;
      }
      redraw = false;
    }
    delay(10);
  }

  drawMenu();
}



String formatUptime() {
  unsigned long ms = millis();
  unsigned long sec = ms / 1000;
  unsigned long min = sec / 60;
  unsigned long hr = min / 60;
  
  char buffer[16];
  sprintf(buffer, "%02lu:%02lu:%02lu", hr, min % 60, sec % 60);
  return String(buffer);
}

void drawRSSIBarMini(int x, int y, int rssi) {
  int width = 30;
  int height = 10;
  
  // Frame
  tft.drawRect(x, y, width, height, ILI9341_DARKGREY);
  
  // Fill
  int percent = map(rssi, -90, -30, 0, 100);
  percent = constrain(percent, 0, 100);
  int barW = (width - 2) * percent / 100;
  
  uint16_t color = ILI9341_GREEN;
  if(rssi < -70) color = ILI9341_YELLOW;
  if(rssi < -80) color = ILI9341_RED;
  
  tft.fillRect(x + 1, y + 1, barW, height - 2, color);
  tft.fillRect(x + 1 + barW, y + 1, (width - 2) - barW, height - 2, ILI9341_BLACK);
}

int countDuplicateSSID(String ssid) {
  int count = 0;
  int n = WiFi.scanComplete();
  if(n < 0) return 0;
  for(int i=0; i<n; i++) {
    if(WiFi.SSID(i) == ssid) count++;
  }
  return count;
}

