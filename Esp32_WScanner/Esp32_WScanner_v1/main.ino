void networkInfo() {
  tft.fillScreen(ILI9341_BLACK);
  
  // Header
  tft.setTextColor(ILI9341_CYAN);
  tft.setTextSize(2);
  tft.setCursor(10, 5);
  tft.print("Network Info");
  
  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(1);
  tft.setCursor(200, 10);
  tft.print("UP: ");
  tft.print(formatUptime());

  tft.drawFastHLine(0, 25, 320, ILI9341_DARKGREY);
  tft.setTextSize(3);
  tft.setCursor(10, 35);
  tft.setTextColor(ILI9341_YELLOW);
  tft.print("Scanning...");

  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  int n = WiFi.scanNetworks();
  
  tft.fillRect(0, 30, 320, 210, ILI9341_BLACK); // Clear "Scanning..."

  if (n == 0) {
    tft.setCursor(10, 40);
    tft.setTextColor(ILI9341_RED);
    tft.print("No networks found");
    delay(2000);
  } else {
    // Navigation state
    int selectedIndex = 0;
    int scrollIndex = 0;
    
    // Adjusted layout for rounded cards
    const int linesPerPage = 6; 
    int cardHeight = 28;
    int cardMargin = 4;
    int listStartY = 35;
    
    bool refresh = true;
    unsigned long lastUpdate = 0;

    while (true) {
      if (digitalRead(button_left) == LOW) { delay(200); break; }
      
      if (digitalRead(button_down) == LOW) {
        selectedIndex++;
        if (selectedIndex >= n) selectedIndex = 0;
        
        // Auto-scroll
        if(selectedIndex >= scrollIndex + linesPerPage) scrollIndex = selectedIndex - linesPerPage + 1;
        if(selectedIndex < scrollIndex) scrollIndex = selectedIndex;
        
        refresh = true;
        delay(150); 
      }
      
      if (digitalRead(button_up) == LOW) {
        selectedIndex--;
        if (selectedIndex < 0) selectedIndex = n - 1;
        
        // Auto-scroll
        if(selectedIndex < scrollIndex) scrollIndex = selectedIndex;
        if(selectedIndex >= scrollIndex + linesPerPage) scrollIndex = selectedIndex - linesPerPage + 1;
        
        refresh = true;
        delay(150);
      }
      
      if (digitalRead(button_select) == LOW) {
          showNetworkDetails(selectedIndex);
          // Redraw full UI after returning
          tft.fillScreen(ILI9341_BLACK);
          tft.setTextColor(ILI9341_CYAN); tft.setTextSize(2);
          tft.setCursor(10, 5); tft.print("Network Info");
          tft.drawFastHLine(0, 25, 320, ILI9341_DARKGREY);
          refresh = true;
          while(digitalRead(button_select) == LOW); // Wait release
      }

      if (millis() - lastUpdate > 1000) {
        lastUpdate = millis();
        tft.fillRect(220, 0, 100, 20, ILI9341_BLACK);
        tft.setTextColor(ILI9341_WHITE);
        tft.setTextSize(1);
        tft.setCursor(220, 10);
        tft.print(formatUptime());
      }
      
      if (refresh) {
        // Clear list area
        tft.fillRect(0, 30, 320, 210, ILI9341_BLACK);
        
        for (int i = 0; i < linesPerPage; i++) {
          int idx = scrollIndex + i;
          if (idx >= n) break;
          
          int y = listStartY + i * (cardHeight + cardMargin);
          
          // Draw Card Background
          if (idx == selectedIndex) {
              tft.fillRoundRect(5, y, 310, cardHeight, 6, ILI9341_BLUE);
              tft.drawRoundRect(5, y, 310, cardHeight, 6, ILI9341_WHITE);
          } else {
              tft.drawRoundRect(5, y, 310, cardHeight, 6, ILI9341_DARKGREY);
          }
          
          // 1. SSID
          tft.setTextColor(ILI9341_WHITE);
          tft.setTextSize(1);
          int textY = y + 10;
          
          tft.setCursor(10, textY);
          String ssid = WiFi.SSID(idx);
          if(ssid.length() > 18) ssid = ssid.substring(0, 15) + "...";
          tft.print(idx + 1); 
          tft.print(". ");
          tft.print(ssid);
          
          // 2. Encryption
          tft.setCursor(170, textY);
          wifi_auth_mode_t enc = WiFi.encryptionType(idx);
          if(enc == WIFI_AUTH_OPEN) {
             tft.setTextColor(ILI9341_GREEN);
             tft.print("OPEN");
          } else {
             tft.setTextColor(ILI9341_RED);
             switch (enc) {
               case WIFI_AUTH_WEP: tft.print("WEP"); break;
               case WIFI_AUTH_WPA_PSK: tft.print("WPA"); break;
               case WIFI_AUTH_WPA2_PSK: tft.print("WPA2"); break;
               case WIFI_AUTH_WPA_WPA2_PSK: tft.print("WPA*"); break;
               case WIFI_AUTH_WPA3_PSK: tft.print("WPA3"); break;
               default: tft.print("LOCK"); break;
             }
          }
          
          // 3. RSSI Value Text
          tft.setTextColor(ILI9341_LIGHTGREY);
          tft.setCursor(215, textY);
          tft.print(WiFi.RSSI(idx));
          
          // 4. RSSI Bar
          drawRSSIBarMini(255, y + 9, WiFi.RSSI(idx));
        }
        refresh = false;
      }
    }
  }
  drawMenu();
}


void setup() {
  Serial.begin(115200);
  
  pinMode(buzzer, OUTPUT);
  pinMode(button_left, INPUT_PULLUP);
  pinMode(button_right, INPUT_PULLUP);
  pinMode(button_up, INPUT_PULLUP);
  pinMode(button_down, INPUT_PULLUP);
  pinMode(button_select, INPUT_PULLUP);

  tft.begin();
  tft.setRotation(1);
  tft.fillScreen(ILI9341_BLACK);

  drawMonoBitmap(boot_logo, LOGO_W, LOGO_H, (tft.width()-LOGO_W)/2, (tft.height()-LOGO_H)/2, ILI9341_WHITE);

  bootBeep();
  delay(1000);

  drawMenu();
}

bool lastUp = HIGH, lastDown = HIGH, lastSelect = HIGH, lastLeft = HIGH;
unsigned long lastBtnTime = 0;
const unsigned long debounceDelay = 150;

void loop() {
  bool up = digitalRead(button_up);
  bool down = digitalRead(button_down);
  bool left = digitalRead(button_left);
  bool select = digitalRead(button_select);

  if (millis() - lastBtnTime < debounceDelay) return;

  if (lastUp == HIGH && up == LOW) { selectedItem--; if (selectedItem<0) selectedItem=menuItems-1; drawMenu(); lastBtnTime=millis();}
  if (lastDown == HIGH && down == LOW) { selectedItem++; if (selectedItem>=menuItems) selectedItem=0; drawMenu(); lastBtnTime=millis();}
  if (lastSelect == HIGH && select == LOW) { lastBtnTime=millis();
    switch(selectedItem){
      case 0: wifiMonitor(); break;
      case 1: vulnerabilities(); break;
      case 2: networkInfo(); break;
    }
  }

  lastUp=up; lastDown=down; lastSelect=select; lastLeft=left;
}
