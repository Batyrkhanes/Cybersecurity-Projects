/* =====DRAW BITMAP ===== */
void drawMonoBitmap(const uint8_t *bitmap, int w, int h, int x, int y, uint16_t color) {
  int byteWidth = (w + 7) / 8;
  for (int j = 0; j < h; j++) {
    for (int i = 0; i < w; i++) {
      if (pgm_read_byte(bitmap + j * byteWidth + i / 8) & (128 >> (i & 7))) {
        tft.drawPixel(x + i, y + j, color);
      }
    }
  }
}

