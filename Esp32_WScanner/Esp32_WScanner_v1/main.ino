/* ===== Sniffer ===== */
void IRAM_ATTR wifiSniffer(void* buf, wifi_promiscuous_pkt_type_t type) {
  const wifi_promiscuous_pkt_t* pkt = (wifi_promiscuous_pkt_t*)buf;
  wm_packets++;
  wm_rssiSum += pkt->rx_ctrl.rssi;
  wm_rssiCount++;
}

/* ===== Wi-Fi Monitor GRAPH===== */
void drawWmGraph() {
  int gx = 10, gy = 160, gw = 220, gh = 60;
  tft.fillRect(gx, gy, gw, gh, ILI9341_BLACK);
  tft.drawRect(gx, gy, gw, gh, ILI9341_DARKGREY);

  for (int i = 1; i < 40; i++) {
    int i1 = (wm_graphIndex + i - 1) % 40;
    int i2 = (wm_graphIndex + i) % 40;
    int x1 = gx + (i - 1) * gw / 40;
    int y1 = gy + gh - map(wm_ppsHistory[i1], 0, wm_maxPPS, 0, gh);
    int x2 = gx + i * gw / 40;
    int y2 = gy + gh - map(wm_ppsHistory[i2], 0, wm_maxPPS, 0, gh);

    tft.drawLine(x1, y1, x2, y2, ILI9341_GREEN);
  }
}

